```
# Laravel-specific ignores
vendor/
composer.lock
.env
.env.local
.env.*
!.env.example

# Build and cache directories
bootstrap/cache/
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
public/storage/

# Logs
storage/logs/*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
.phpunit.result.cache
coverage/
.htmlcov/

# Compiled files
*.php~
*.o
*.obj
*.out

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archives
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
```